{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CShells": {
    "SharedAssemblies": [
      "CShells.Workbench.Features",
      "CShells.Workbench.Features.*"
    ],
    "Shells": {
      "Default": {
        "Features": {
          "Core": true,
          "Posts": true,
          "Analytics": false
        },
        "Configuration": {
          "WebRouting": {
            "Path": ""
          },
          "Plan": "Free"
        }
      },
      "Acme": {
        "Features": {
          "Core": true,
          "Posts": true,
          "Comments": true,
          "Analytics": false
        },
        "Configuration": {
          "WebRouting": {
            "Path": "acme"
          },
          "Plan": "Pro"
        }
      },
      "Contoso": {
        "Features": {
          "Core": true,
          "Posts": true,
          "Comments": true,
          "Analytics": { "TopPostsCount": 10 }
        },
        "Configuration": {
          "WebRouting": {
            "Path": "contoso"
          },
          "Plan": "Enterprise"
        }
      }
    }
  }
}
